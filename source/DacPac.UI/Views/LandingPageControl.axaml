<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModel="clr-namespace:DacPac.UI.ViewModels"
             x:DataType="viewModel:LandingPageControlViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DacPac.UI.Views.LandingPageControl">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">

        <!-- Search bar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     PlaceholderText="Search…"
                     VerticalAlignment="Top"
                     Text="{Binding SearchText}" />
            <ListBox Grid.Column="1"
                     MinWidth="160"
                     MaxHeight="120"
                     SelectionMode="Multiple"
                     ItemsSource="{Binding FilterOptions}"
                     SelectedItems="{Binding SelectedFilters}" />
            <Button Grid.Column="2"
                    Classes="Accent"
                    Content="Search"
                    VerticalAlignment="Top"
                    Command="{Binding SearchCommand}" />
        </Grid>

        <!-- Results split -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*">
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedResult}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Database" Binding="{Binding Database}" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns" />

            <TextBox Grid.Column="2"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Text="{Binding DetailsText}" />
        </Grid>
    </Grid>
</UserControl>
